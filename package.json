{
  "name": "sellmind",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently --kill-others --names \"api,web\" --prefix-colors \"magenta,cyan\" \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
