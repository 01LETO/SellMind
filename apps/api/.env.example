PORT=3001

# Supabase — obtenha em: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # nunca expor ao browser
SUPABASE_ANON_KEY=your-anon-key

# Anthropic Claude — obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Modelo Claude a usar (padrão: claude-opus-4-7)
CLAUDE_MODEL=claude-opus-4-7

# Stripe — obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (usado para redirect do Stripe e CORS)
FRONTEND_URL=http://localhost:5173
# Origins adicionais permitidas no CORS (separe por vírgula — use para Vercel preview URLs)
# Exemplo: CORS_EXTRA_ORIGINS=https://sell-mind-web-abc123.vercel.app,https://staging.sellmind.com
CORS_EXTRA_ORIGINS=

# Sentry — obtenha em: https://sentry.io (deixe vazio para desativar)
SENTRY_DSN=

# Log level: error | warn | info | http | debug (padrão: info)
LOG_LEVEL=info

# Defina como "true" para expor /docs em produção (desabilitado por padrão)
DOCS_ENABLED=
